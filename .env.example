# rent.co — environment configuration
# Copy to .env.local and fill in as needed. All values are optional for local dev.

# Where inquiry submissions are forwarded. If set, the /api/inquiry route POSTs
# each submission (JSON) to this URL — wire it to a CRM, Zapier, Make, or an
# email-relay webhook. If unset, submissions are logged and stored locally only.
INQUIRY_WEBHOOK_URL=

# Operator contact surfaced in the UI and used as the mailto fallback.
NEXT_PUBLIC_CONTACT_EMAIL=hello@r-ent.co
